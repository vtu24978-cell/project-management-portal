PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=24h

# Database Configuration
# Dialect can be 'sqlite' or 'mysql'
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# MySQL Details (Uncomment and configure if DB_DIALECT=mysql)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=your_password
# DB_NAME=task_db

# Email / SMTP Configuration (Optional - for task assignment email notifications)
# If not set, notifications will be printed to the server console instead.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_gmail_address@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="TaskFlow System" <noreply@taskflow.com>
